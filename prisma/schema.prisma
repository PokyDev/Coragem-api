generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────

enum Category {
  EARCUFF
  ANILLO
  DIJE
  CADENA
  TOPOS
  CANDONGAS
  CONJUNTOS
}

enum Color {
  ROJO
  NEGRO
  BLANCO
  ROSADO
  SILVER
}

// ── Modelos ───────────────────────────────────────

model Product {
  id          String    @id @default(cuid())
  name        String
  description String?
  price       Int
  category    Category
  color       Color
  stock       Int       @default(0)
  ventas      Int       @default(0)
  isVisible   Boolean   @default(true)
  images      Image[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([category])
  @@index([color])
  @@index([isVisible])
}

model Image {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String                        // URL de Cloudinary
  publicId  String                        // public_id de Cloudinary (para eliminar)
  order     Int      @default(0)
  width     Int?
  height    Int?
  createdAt DateTime @default(now())

  @@index([productId])
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model AppConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}